generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  formEntries FormEntry[]
  auditLogs   AuditLog[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── REFERENCE DATA ─────────────────────────────────────────────

model District {
  id             String         @id @default(cuid())
  nameTamil      String         @unique
  nameEnglish    String         @unique
  code           String         @unique
  constituencies Constituency[]
  formEntries    FormEntry[]

  @@map("districts")
}

model Constituency {
  id          String      @id @default(cuid())
  nameTamil   String
  nameEnglish String
  code        String      @unique
  districtId  String
  district    District    @relation(fields: [districtId], references: [id])
  formEntries FormEntry[]
  members     ConstituencyMember[]

  @@unique([nameTamil, districtId])
  @@index([districtId])
  @@map("constituencies")
}

// ─── CORE DOMAIN ────────────────────────────────────────────────

model FormEntry {
  id                  String        @id @default(cuid())

  serialNumber        String?
  feeReceiptNumber    String?

  districtId          String?
  district            District?     @relation(fields: [districtId], references: [id])
  constituencyId      String?
  constituency        Constituency? @relation(fields: [constituencyId], references: [id])
  rawDistrictText     String?
  rawConstituencyText String?

  name           String?
  parentName     String?
  parentType     ParentType?
  address        String?     @db.Text
  contactNumber  String?

  yearJoinedParty Int?
  partyPosition   String?
  entryDate       DateTime?
  entryPlace      String?

  applicationGivenBy String?
  applicationGivenTo String?
  forThalaivar       Boolean @default(false)
  paymentMode        String?

  ocrStatus          OcrStatus @default(PENDING)
  ocrJobId           String?   @unique
  ocrConfidenceScore Float?
  ocrRawResponse     Json?
  ocrProcessedAt     DateTime?
  ocrErrorMessage    String?   @db.Text

  imageUrl      String
  imageKey      String  @unique
  imageMimeType String
  imageSizeBytes Int?

  isVerified   Boolean  @default(false)
  verifiedAt   DateTime?
  verifiedById String?
  lastEditedAt DateTime?

  reviewingById String?
  reviewingAt   DateTime?

  submittedById String
  submittedBy   User      @relation(fields: [submittedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs AuditLog[]

  @@index([submittedById])
  @@index([districtId])
  @@index([constituencyId])
  @@index([ocrStatus])
  @@index([name])
  @@index([serialNumber])
  @@index([createdAt])
  @@map("form_entries")
}

// ─── CONSTITUENCY POSTINGS ──────────────────────────────────────

model PostingType {
  id          String   @id @default(cuid())
  nameTamil   String
  nameEnglish String
  bodyType    BodyType @default(MAIN_BODY)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members ConstituencyMember[]

  @@index([bodyType])
  @@map("posting_types")
}

model ConstituencyMember {
  id             String      @id @default(cuid())
  constituencyId String
  constituency   Constituency @relation(fields: [constituencyId], references: [id])
  postingTypeId  String
  postingType    PostingType @relation(fields: [postingTypeId], references: [id])

  name              String
  address           String?   @db.Text
  age               Int?
  gender            Gender?
  contact           String?
  alternateContact  String?
  email             String?
  partyMembershipId String?
  photoKey          String?

  facebook   String?
  instagram  String?
  x          String?
  whatsapp   String?
  youtube    String?
  linkedin   String?
  telegram   String?

  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([constituencyId])
  @@index([postingTypeId])
  @@map("constituency_members")
}

model AuditLog {
  id        String    @id @default(cuid())
  entryId   String
  entry     FormEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  action    String
  changes   Json?
  createdAt DateTime  @default(now())

  @@index([entryId])
  @@index([userId])
  @@map("audit_logs")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  MANUAL
}

enum ParentType {
  FATHER
  MOTHER
}

enum BodyType {
  MAIN_BODY
  SUB_BODY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ─── PUBLIC SITE CONTENT ────────────────────────────────────────

model Leader {
  id              String   @id @default(cuid())
  name            String
  nameTA          String?
  designation     String
  designationTA   String?
  bio             String?
  photoUrl        String?
  order           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("leaders")
}

model ElectedMember {
  id           String   @id @default(cuid())
  name         String
  nameTA       String?
  constituency String
  role         String
  photoUrl     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("elected_members")
}

model PartyWing {
  id          String   @id @default(cuid())
  name        String
  nameTA      String?
  description String?
  leaderName  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("party_wings")
}

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  titleTA     String?
  body        String
  category    String
  thumbnail   String?
  publishedAt DateTime @default(now())
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("news_articles")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  formEntries FormEntry[]
  auditLogs   AuditLog[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── REFERENCE DATA ─────────────────────────────────────────────

model District {
  id             String         @id @default(cuid())
  nameTamil      String         @unique
  nameEnglish    String         @unique
  code           String         @unique
  constituencies Constituency[]
  formEntries    FormEntry[]

  @@map("districts")
}

model Constituency {
  id          String      @id @default(cuid())
  nameTamil   String
  nameEnglish String
  code        String      @unique
  districtId  String
  district    District    @relation(fields: [districtId], references: [id])
  formEntries FormEntry[]

  @@unique([nameTamil, districtId])
  @@index([districtId])
  @@map("constituencies")
}

// ─── CORE DOMAIN ────────────────────────────────────────────────

model FormEntry {
  id                  String        @id @default(cuid())

  serialNumber        String?
  feeReceiptNumber    String?

  districtId          String?
  district            District?     @relation(fields: [districtId], references: [id])
  constituencyId      String?
  constituency        Constituency? @relation(fields: [constituencyId], references: [id])
  rawDistrictText     String?
  rawConstituencyText String?

  name           String?
  parentName     String?
  parentType     ParentType?
  address        String?     @db.Text
  contactNumber  String?

  yearJoinedParty Int?
  partyPosition   String?
  entryDate       DateTime?
  entryPlace      String?

  ocrStatus          OcrStatus @default(PENDING)
  ocrJobId           String?   @unique
  ocrConfidenceScore Float?
  ocrRawResponse     Json?
  ocrProcessedAt     DateTime?
  ocrErrorMessage    String?   @db.Text

  imageUrl      String
  imageKey      String  @unique
  imageMimeType String
  imageSizeBytes Int?

  isVerified   Boolean  @default(false)
  verifiedAt   DateTime?
  verifiedById String?
  lastEditedAt DateTime?

  submittedById String
  submittedBy   User      @relation(fields: [submittedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs AuditLog[]

  @@index([submittedById])
  @@index([districtId])
  @@index([constituencyId])
  @@index([ocrStatus])
  @@index([name])
  @@index([serialNumber])
  @@index([createdAt])
  @@map("form_entries")
}

model AuditLog {
  id        String    @id @default(cuid())
  entryId   String
  entry     FormEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  action    String
  changes   Json?
  createdAt DateTime  @default(now())

  @@index([entryId])
  @@index([userId])
  @@map("audit_logs")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  MANUAL
}

enum ParentType {
  FATHER
  MOTHER
}
